# ── Embedding ─────────────────────────────────────
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── ChromaDB ──────────────────────────────────────
CHROMA_PATH=./data/chroma
COLLECTION_NAME=docmind_chunks

# ── Pinecone (NEW Week 4) ────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=docmind
PINECONE_ENVIRONMENT=us-east-1
VECTOR_STORE_PROVIDER=chroma

# ── Chunking ──────────────────────────────────────
DEFAULT_CHUNK_SIZE=500
DEFAULT_CHUNK_OVERLAP=100

# ── API Keys (fill in yours) ─────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=

# ── Azure OpenAI (use instead of standard OpenAI) ─
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ── LLM Generation ───────────────────────────────
DEFAULT_LLM_PROVIDER=openai
OPENAI_CHAT_MODEL=gpt-4o-mini
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-20250514
MISTRAL_CHAT_MODEL=mistral-small-latest

# ── Retrieval ─────────────────────────────────────
DEFAULT_TOP_K=5
RERANK_TOP_N=3
COHERE_RERANK_MODEL=rerank-v3.5

# ── Evaluation ────────────────────────────────────
EVAL_DATASET_PATH=./data/eval/dataset.json
EVAL_LLM_JUDGE_PROVIDER=openai
RESULTS_DIR=./results

# ── API Server (NEW Week 4) ──────────────────────
API_HOST=0.0.0.0
API_PORT=8000
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
